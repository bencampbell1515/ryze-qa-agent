# Anthropic API key — used by validate, summarise, categorise, semantic-dedup,
# visual-gate, personas, and the daemon's semantic diff pass.
# Without it, all LLM steps no-op silently (visual gate still ships a "degraded" banner).
ANTHROPIC_API_KEY=sk-ant-...

# Path to Firebase Admin service-account JSON used by scripts/runner-daemon.ts.
# Defaults to ~/.config/ryze-qa/service-account.json when unset.
# File MUST be chmod 600.
GOOGLE_APPLICATION_CREDENTIALS=/Users/you/.config/ryze-qa/service-account.json

# Set to "1" to skip the visual-gate LLM pass during orchestrate. Useful while
# iterating on report layout. See CLAUDE.md "Visual verification gate".
# DISABLE_VISUAL_GATE=1
