{
  "name": "ryze-qa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test:crawl": "tsx scripts/crawl.ts",
    "test:audit": "playwright test tests/crawl.spec.ts --grep @audit",
    "test:unit": "playwright test tests/unit/ tests/cross-page/ tests/discovery/ tests/visual-regression/ tests/journeys/ --reporter=line",
    "test:smoke": "playwright test tests/smoke/ --reporter=line",
    "lint:personas": "tsx scripts/lint-personas.ts",
    "report": "tsx scripts/report.ts",
    "clean": "rm -f data/bugs.jsonl data/tmp/*.txt data/validated-bugs.jsonl data/discoveries.jsonl data/scored-bugs.json && rm -f output/audit-report-*.html output/audit-report-*.pdf && rm -rf output/screenshots && mkdir -p output/screenshots",
    "dismiss": "tsx scripts/dismiss.ts",
    "validate": "tsx scripts/validate.ts",
    "discover": "tsx scripts/discover.ts",
    "discover:agentic": "tsx scripts/discover-agentic.ts",
    "reverify": "tsx scripts/reverify.ts",
    "orchestrate": "tsx scripts/orchestrate.ts",
    "full-audit": "npm run clean && npm run test:crawl && npx tsx scripts/run-audit.ts && npm run orchestrate",
    "audit-only": "npm run clean && npm run test:crawl && npm run test:audit && npm run report",
    "daemon": "tsx scripts/runner-daemon.ts",
    "tsc": "tsc --noEmit"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@cspell/dict-es-es": "^3.0.8",
    "@playwright/test": "^1.50.0",
    "@types/node": "^20.0.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "cspell": "^8.0.0",
    "docx": "^9.0.0",
    "fast-xml-parser": "^4.5.0",
    "lighthouse": "^12.0.0",
    "linkinator": "^6.1.0",
    "p-limit": "^6.0.0",
    "playwright-lighthouse": "^4.0.0",
    "robots-parser": "^3.0.0",
    "sharp": "^0.33.0",
    "sharp-phash": "^2.2.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "zod": "^3.23.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.94.0",
    "dotenv": "^17.4.2",
    "firebase-admin": "^13.10.0",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0"
  }
}
