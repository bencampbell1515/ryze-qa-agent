    "sharp-phash": "^2.2.0",
    "cspell": "^8.0.0",
    "docx": "^9.0.0",
    "fast-xml-parser": "^4.5.0",
    "robots-parser": "^3.0.0",
    "p-limit": "^6.0.0",
    "zod": "^3.23.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0"
