{
  "version": "0.2",
  "language": "en,es",
  "import": ["@cspell/dict-es-es/cspell-ext.json"],
  "dictionaryDefinitions": [
    {
      "name": "ryze-brand",
      "path": "./data/brand-dictionary.txt",
      "addWords": true
    }
  ],
  "dictionaries": ["en_US", "es-es", "ryze-brand"],
  "minWordLength": 5,
  "ignoreRegExpList": [
    "\\b[A-Z][a-z]+ [A-Z]\\.",
    "^[A-Z][a-zA-Z]+ [A-Z][a-zA-Z]+$",
    "[찼챕챠처첬챰체횁횋횒횙횣횗횥]"
  ],
  "ignorePaths": [
    "node_modules",
    "output",
    "dist",
    "data/bugs.jsonl"
  ]
}
